# AI Dub Studio — Environment Variables
# Copy this file to .env and fill in your paths

HF_HOME=/mnt/d/$/dub_requirements/hf_cache
TRANSFORMERS_CACHE=/mnt/d/$/dub_requirements/hf_cache
HF_DATASETS_CACHE=/mnt/d/$/dub_requirements/hf_cache/datasets
TORCH_HOME=/mnt/d/$/dub_requirements/torch_cache
WHISPER_CACHE=/mnt/d/$/dub_requirements/whisper_cache
PIP_CACHE_DIR=/mnt/d/$/dub_requirements/pip_cache
PROJECT_ROOT=/mnt/d/$/my/dubbing_V2
CUDA_VISIBLE_DEVICES=0
